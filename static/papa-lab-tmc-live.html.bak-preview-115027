async function repeaterSend(){
  const method=document.getElementById('rep-method').value;
  const path=document.getElementById('rep-path').value.trim();
  const bodyTxt=document.getElementById('rep-body').value.trim();
  const url=path.startsWith('http')?path:getTargetUrl()+path;
  const hdrs={};_repHeaders.forEach(h=>{if(h.k)hdrs[h.k]=h.v;});
  const opts={method,headers:hdrs};
  if(bodyTxt&&method!=='GET'&&method!=='DELETE')opts.body=bodyTxt;
  const t0=Date.now();
  let status=0,statusText='',respHeaders={},respBody='';
  try{
    const r=await fetch(url,opts);
    status=r.status;statusText=r.statusText;
    respHeaders={};r.headers.forEach((v,k)=>respHeaders[k]=v);
    respBody=await r.text();
    try{respBody=JSON.stringify(JSON.parse(respBody),null,2);}catch(e){}
  }catch(e){respBody='Error: '+e.message;status=0;statusText='Network Error';}
  const elapsed=Date.now()-t0;
  // Display
  const statusCls=status>=500?'resp-5xx':status>=300?'resp-3xx resp-4xx':'resp-2xx';
  document.getElementById('rep-status-badge').className='resp-status '+(status?statusCls:'resp-5xx');
  document.getElementById('rep-status-badge').textContent=status?(status+' '+statusText):'ERR';
  document.getElementById('rep-time-badge').textContent=elapsed+'ms';
  document.getElementById('rep-resp-headers-body').innerHTML=Object.entries(respHeaders).map(([k,v])=>`<div style="margin-bottom:2px"><span style="color:var(--tmc)">${escHtml(k)}:</span> ${escHtml(v)}</div>`).join('');
  document.getElementById('rep-resp-body').textContent=respBody;
  document.getElementById('rep-response-section').style.display='block';
  // History
  if(!S.reconHistory)S.reconHistory=[];
  S.reconHistory.unshift({method,path,url,status,elapsed,body:respBody.slice(0,500),hdrs:respHeaders,ts:Date.now()});
  if(S.reconHistory.length>10)S.reconHistory.length=10;
  schedSave();
  renderRepHistory();
}

function renderRepHistory(){
  const el=document.getElementById('rep-history-list');if(!el)return;
  const hist=S.reconHistory||[];
  if(!hist.length){el.innerHTML='<div style="font-size:10px;color:var(--text3)">No requests yet.</div>';return;}
  el.innerHTML=hist.map((h,i)=>{
    const cls=h.status>=500?'resp-5xx':h.status>=300?'resp-3xx resp-4xx':'resp-2xx';
    return`<div class="hist-row" onclick="loadHistoryItem(${i})">
      <span style="color:var(--tmc);font-size:9px;min-width:45px">${h.method}</span>
      <span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${escHtml(h.path||h.url)}</span>
