async function doLogin(){
  const email=document.getElementById('login-email').value.trim();
  const pwd=document.getElementById('login-pwd').value.trim();
  const msg=document.getElementById('login-msg');
  if(!email||!pwd){msg.textContent='Email and password required';return;}
  if(!_liveMode){
    // Simulated login
    const known={'customer@example.com':'customer123','admin@toomanycables.com':'admin123'};
    if(known[email]===pwd){
      const isAdmin=email.includes('admin');
      S.auth={loggedIn:true,email,role:isAdmin?'admin':'customer',firstName:isAdmin?'Admin':'Test',lastName:isAdmin?'User':'Customer'};
      schedSave();closeLoginModal();updateAuthUI();showToast('Logged in as '+email+' (simulated)');
    } else {msg.textContent='Invalid credentials';}
    return;
  }
  try{
    msg.textContent='Logging in…';
    // credentials:'include' requires CORS supports_credentials=True on server.
    // When served from localhost:5001/static/ (same-origin) this is irrelevant.
    // When served cross-origin, omit credentials so the CORS wildcard allows the request.
    const sameOrigin=window.location.host===getTargetUrl().replace(/^https?:\/\//,'').split('/')[0];
    const r=await fetch(getTargetUrl()+(S.config?.loginPath||'/api/login'),{
      method:'POST',credentials:sameOrigin?'include':'omit',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({email,password:pwd})
