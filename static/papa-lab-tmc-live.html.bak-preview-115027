async function sendPromptLive(scId,text){
  const convId=S.conversations[scId]||null;
  const sameOrigin=window.location.host===getTargetUrl().replace(/^https?:\/\//,'').split('/')[0];
  const r=await fetch(getTargetUrl()+(S.config?.chatPath||'/api/chat'),{
    method:'POST',credentials:sameOrigin?'include':'omit',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({message:text,conversation_id:convId})
  });
  if(!r.ok)throw new Error('HTTP '+r.status);
  const d=await r.json();
  if(d.conversation_id&&!S.conversations[scId]){S.conversations[scId]=d.conversation_id;schedSave();}
  return d;
}

