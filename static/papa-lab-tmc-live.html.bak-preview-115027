  const tester=m.tester||'[Tester Name]';const client=m.client||'Too Many Cables';
  const modeHeader=_mode==='client'?'  Client Engagement Report — custom findings\n':'';
  let r=`${'═'.repeat(62)}\n  AI APPLICATION SECURITY ASSESSMENT — FINDINGS REPORT\n${modeHeader}  Too Many Cables (TMC) · BUSINESS CONFIDENTIAL\n${'═'.repeat(62)}\n\n`;
  r+=`Organisation: ${client}\nDate:         ${date}\nProject:      ${m.project||'AI-SEC-001'}\nTester:       ${tester}\nSecurity Level Tested: ${S.securityLevel}\n${S.modelIdentification?'AI Model Identified: '+S.modelIdentification+'\n':''}\n`;
  r+=`${'─'.repeat(60)}\nEXECUTIVE SUMMARY\n${'─'.repeat(60)}\n${ex.result||'[Complete Security Assessment Result]'}\n\n`;
  if(ex.threatActivities)r+=`THREAT ACTIVITIES:\n${ex.threatActivities}\n\n`;
  r+=`${'─'.repeat(60)}\nVULNERABILITY SUMMARY\n${'─'.repeat(60)}\n`;
  r+=`${'ID'.padEnd(12)} ${'Vulnerability'.padEnd(44)} ${'Sev'.padEnd(10)} Level\n${'-'.repeat(70)}\n`;
  for(const f of findings){const fd=getFD(Object.keys(FM).find(k=>FM[k].id===f.id)||'');r+=`${f.id.padEnd(12)} ${f.title.padEnd(44)} ${f.severity.padEnd(10)} L${fd.securityLevel||S.securityLevel}\n`;}
  for(const cf of clientFindings){r+=`${cf.id.padEnd(12)} ${(cf.title||'Untitled').padEnd(44)} ${cf.severity.padEnd(10)} —\n`;}
  r+='\n';
  findings.forEach((f,i)=>{
    const key=Object.keys(FM).find(k=>FM[k].id===f.id)||'';const fd=getFD(key);const sc=SCENARIOS.find(s=>s.id===f.scenario);
    r+=`\n${'═'.repeat(60)}\nFinding ${i+1}: ${f.title}\n${'═'.repeat(60)}\n`;
    r+=`ID: ${f.id} | Severity: ${f.severity} | Level: L${fd.securityLevel||S.securityLevel} | OWASP: ${f.owaspRef}\nSystem: ${sc?.target||'—'}\nRisk: ${fd.risk||f.risk}\nDescription: ${fd.description||f.description}\nRemediation: ${fd.remediation||f.remediation}\n`;
    r+=`\nWeakness Narrative:\n${fd.weaknessNarrative||'[Not yet written]'}\n\nExploitation PoC:\n${fd.exploitationPoC||'[Not yet documented]'}\n`;
    if(fd.stepsTaken)r+=`\nSteps Taken:\n${fd.stepsTaken}\n`;
  });
  clientFindings.forEach((cf,i)=>{
    r+=`\n${'═'.repeat(60)}\nClient Finding ${i+1}: ${cf.title||'Untitled'}\n${'═'.repeat(60)}\n`;
    r+=`ID: ${cf.id} | Severity: ${cf.severity} | OWASP: ${cf.owaspRef||'—'}\nRisk: ${cf.risk||'—'}\nDescription: ${cf.description||'—'}\nRemediation: ${cf.remediation||'—'}\n`;
    r+=`\nWeakness Narrative:\n${cf.weaknessNarrative||'[Not yet written]'}\n\nExploitation PoC:\n${cf.exploitationPoC||'[Not yet documented]'}\n`;
    if(cf.stepsTaken)r+=`\nSteps Taken:\n${cf.stepsTaken}\n`;
  });
  return r;
}
