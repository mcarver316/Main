// Compress image to max 1024px wide JPEG before sending to AI (Retina screenshots can be 5MB+)
function compressImageForAI(dataUrl,maxW=1024){
  return new Promise(resolve=>{
    const img=new Image();
    img.onload=()=>{
      const ratio=Math.min(1,maxW/img.width);
      const c=document.createElement('canvas');
      c.width=Math.round(img.width*ratio);c.height=Math.round(img.height*ratio);
      c.getContext('2d').drawImage(img,0,0,c.width,c.height);
      resolve(c.toDataURL('image/jpeg',0.82));
    };
    img.onerror=()=>resolve(dataUrl); // fallback to original
    img.src=dataUrl;
  });
}

async function analyseScreenshotWithAI(cfId,imageDataUrl){
  const cf=(S.clientFindings||[]).find(cf=>cf.id===cfId);
  if(!cf)return;
  const model=S.config?.aiModel||'unsloth/qwen3.6-35b-a3b-mlx';
  const apiUrl=S.config?.aiUrl||'http://localhost:1234';
  if(!S.aiDrafts)S.aiDrafts={};
  S.aiDrafts[cfId]={loading:true};
  schedSave();renderRepEdit();
  // Compress image — Retina screenshots are 5MB+, browser aborts large fetch bodies
  const compressedUrl=await compressImageForAI(imageDataUrl,1024);
  const prompt=`You are a professional AI security consultant writing a penetration test report.\nAnalyse this screenshot from an AI pentest engagement.\n\nFinding context:\n- Title: ${cf.title||'(untitled finding)'}\n- OWASP Category: ${cf.owaspRef||'Unknown'}\n- Severity: ${cf.severity}\n- Target: ${S.meta?.client||'Target application'}\n\nFrom the screenshot, extract and write professionally:\n1. WEAKNESS NARRATIVE — a professional paragraph describing the attack chain, why it succeeded, and the security impact\n2. EXPLOITATION POC — the exact payload sent and response received (quote verbatim if visible in the screenshot)\n3. STEPS TAKEN — numbered methodology steps visible or implied in the screenshot\n4. RISK — one concise sentence on likelihood and impact\n\nReturn ONLY valid JSON with exactly these keys (no markdown, no extra text):\n{"weaknessNarrative":"...","exploitationPoC":"...","stepsTaken":"...","risk":"..."}`;
  try{
    const r=await fetch(apiUrl+'/v1/chat/completions',{
      method:'POST',
      mode:'cors',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({
        model,
        messages:[{role:'user',content:[
          {type:'text',text:prompt},
          {type:'image_url',image_url:{url:compressedUrl}}
        ]}],
        max_tokens:2000,
        temperature:0.3,
        thinking:{type:'disabled'}  // Qwen3: disable reasoning chain, output goes to content
      })
    });
    if(!r.ok)throw new Error('HTTP '+r.status+' — '+await r.text().catch(()=>''));
    const d=await r.json();
    const msg=d.choices?.[0]?.message||{};
    // Fallback: some model versions still use reasoning_content even with thinking disabled
    const text=(msg.content||'').trim()||(msg.reasoning_content||'').replace(/<think>[\s\S]*?<\/think>/g,'').trim()||'';
    const match=text.match(/\{[\s\S]*\}/);
    if(!match)throw new Error('No JSON in response — model said: '+text.slice(0,120));
    const draft=JSON.parse(match[0]);
    S.aiDrafts[cfId]={loading:false,draft};
    schedSave();renderRepEdit();
    showToast('AI draft ready — review and accept each field');
  }catch(e){
    S.aiDrafts[cfId]={loading:false,error:e.message};
    schedSave();renderRepEdit();
    showToast('AI error: '+e.message);
  }
}

function acceptAIDraft(cfId,field){
  const d=S.aiDrafts?.[cfId]?.draft;
  if(!d||!d[field])return;
  updateCF(cfId,field,d[field]);
  if(!S.aiDrafts[cfId]._accepted)S.aiDrafts[cfId]._accepted={};
  S.aiDrafts[cfId]._accepted[field]=true;
  schedSave();renderRepEdit();
}

function discardAIDraft(cfId,field){
  if(!S.aiDrafts?.[cfId]?.draft)return;
  delete S.aiDrafts[cfId].draft[field];
  schedSave();renderRepEdit();
}

function dismissAIDraft(cfId){
  delete S.aiDrafts[cfId];
  schedSave();renderRepEdit();
}

function handleInlineSs(cfId,dataUrl){
  const cf=(S.clientFindings||[]).find(cf=>cf.id===cfId);
  if(!cf)return;
  if(!cf.screenshots)cf.screenshots=[];
  const ssId='ss-'+Date.now()+'-'+Math.random().toString(36).slice(2);
  cf.screenshots.push({id:ssId,dataUrl,caption:'',findingKey:cfId});
  schedSave();
  document.getElementById('ss-tab-btn').textContent=`📷 SCREENSHOTS (${getAllScreenshots().length})`;
  analyseScreenshotWithAI(cfId,dataUrl);
}

function triggerInlineUpload(cfId){const el=document.getElementById('ifile-'+cfId);if(el)el.click();}
function handleInlineDrop(cfId,e){for(const f of e.dataTransfer.files){if(!f.type.startsWith('image/'))continue;const r=new FileReader();r.onload=ev=>handleInlineSs(cfId,ev.target.result);r.readAsDataURL(f);break;}}
function handleInlineFile(cfId,e){const f=e.target.files?.[0];if(!f)return;const r=new FileReader();r.onload=ev=>handleInlineSs(cfId,ev.target.result);r.readAsDataURL(f);e.target.value='';}

function reorderCF(id,dir){
  const arr=S.clientFindings||[];
  const idx=arr.findIndex(cf=>cf.id===id);
  if(idx<0)return;
  const to=dir==='up'?idx-1:idx+1;
  if(to<0||to>=arr.length)return;
  [arr[idx],arr[to]]=[arr[to],arr[idx]];
  schedSave();renderRepEdit();
}

function duplicateCF(id){
  const arr=S.clientFindings||[];
  const cf=arr.find(cf=>cf.id===id);
  if(!cf)return;
  const n=arr.length+1;
  arr.push({...JSON.parse(JSON.stringify(cf)),id:'CF-'+String(n).padStart(3,'0'),screenshots:[],title:(cf.title||'')+(cf.title?' (copy)':'')});
  schedSave();renderRepEdit();
}

