      schedSave();closeLoginModal();updateAuthUI();showToast('Logged in as '+email);
    } else {msg.textContent=d.error||'Login failed';}
  }catch(e){msg.textContent='Connection error — is the chatbot running?';}
}

async function doLogout(){
