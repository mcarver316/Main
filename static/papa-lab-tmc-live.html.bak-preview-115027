  if(!recon.length){showToast('No recon results to import. Run a scan first.');return;}
  const items=recon.map(r=>({id:r.path+'_'+r.method,title:r.method+' '+r.path+' → '+r.status,
    severity:'Medium',owasp:'LLM02:2025 – Sensitive Information Disclosure',
    description:'HTTP '+r.status+' from '+r.method+' '+r.path,risk:'',remediation:'',
    weaknessNarrative:'',exploitationPoC:'Method: '+r.method+'\nPath: '+r.path+'\nStatus: '+r.status+(r.note?'\nNote: '+r.note:''),stepsTaken:''}));
  showImportModal('Import from Recon Results',items,'recon');
}

function showImportModal(title,items,source){
  window._importItems=items;
  document.getElementById('import-modal-title').textContent=title;
  document.getElementById('import-modal-list').innerHTML=items.map((it,i)=>`
    <label style="display:flex;gap:8px;padding:6px 0;border-bottom:1px solid var(--border);cursor:pointer;font-size:12px">
      <input type="checkbox" data-idx="${i}" style="flex-shrink:0;margin-top:2px">
      <span><strong style="color:var(--text)">${escHtml(it.title)}</strong>
        <span style="font-size:10px;color:var(--text3)"> — ${escHtml(it.severity)}</span>
      </span>
    </label>`).join('');
  document.getElementById('import-modal').style.display='flex';
}

function closeImportModal(){document.getElementById('import-modal').style.display='none';}

function executeImport(){
  const checks=document.querySelectorAll('#import-modal-list input[type=checkbox]:checked');
  if(!checks.length){showToast('Select at least one item');return;}
  if(!S.clientFindings)S.clientFindings=[];
  checks.forEach(cb=>{
    const it=window._importItems[parseInt(cb.dataset.idx)];
    if(!it)return;
    const n=S.clientFindings.length+1;
    S.clientFindings.push({id:'CF-'+String(n).padStart(3,'0'),title:it.title,severity:it.severity||'Medium',
      owaspRef:it.owasp||OWASP_REFS[0],risk:it.risk||'',description:it.description||'',
      remediation:it.remediation||'',weaknessNarrative:it.weaknessNarrative||'',
      exploitationPoC:it.exploitationPoC||'',stepsTaken:it.stepsTaken||'',screenshots:[]});
  });
  schedSave();closeImportModal();renderRepEdit();
  showToast(`${checks.length} finding(s) imported`);
}

