function showToast(msg){
  const t=document.createElement('div');
  t.style.cssText='position:fixed;bottom:24px;right:24px;background:#0a0e1a;border:1px solid #00c8ff;border-radius:6px;padding:10px 16px;font-size:12px;color:#00c8ff;z-index:9999;font-family:var(--font)';
