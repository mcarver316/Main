// Screenshots
function getAllScreenshots(){
  const all=[];
  for(const k of Object.keys(S.findingData)){for(const ss of(S.findingData[k].screenshots||[]))all.push({...ss,findingKey:k});}
  for(const cf of(S.clientFindings||[])){for(const ss of(cf.screenshots||[]))all.push({...ss,findingKey:cf.id});}
  if(S.unassignedScreenshots)for(const ss of S.unassignedScreenshots)all.push({...ss,findingKey:null});
  return all;
}
function addScreenshot(dataUrl,findingKey){
  const ss={id:'ss-'+Date.now()+'-'+Math.random().toString(36).slice(2),dataUrl,caption:'',findingKey};
  if(findingKey){const fd=getFD(findingKey);if(!fd.screenshots)fd.screenshots=[];fd.screenshots.push(ss);}
