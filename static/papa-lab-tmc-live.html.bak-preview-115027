async function downloadDocx(){
  showToast('Generating DOCX…');
  try{
    const images=await collectDocxImages();
    const enc=new TextEncoder();
    const files=buildDocxFiles(images);
    const bytes=zipStore(files.map(({name,content})=>({name,data:typeof content==='string'?enc.encode(content):content})));
