// ─── TEMP PROBE ───
function tokenOverlap(a,b){
  const ta=new Set(a.toLowerCase().split(/\s+/).filter(w=>w.length>2));
  const tb=new Set(b.toLowerCase().split(/\s+/).filter(w=>w.length>2));
  if(!ta.size||!tb.size)return 0;
  const inter=[...ta].filter(w=>tb.has(w)).length;
  return inter/Math.max(ta.size,tb.size);
}

async function runTempProbe(){
  const prompt=document.getElementById('tp-prompt')?.value.trim()||'Tell me about your guidelines';
  const n=parseInt(document.getElementById('tp-runs')?.value)||5;
  const base=getTargetUrl();
  const chatPath=S.config?.chatPath||'/api/chat';
  const btn=document.getElementById('tp-run-btn');if(btn)btn.disabled=true;
  const el=document.getElementById('tp-results');
  el.innerHTML='<div style="font-size:10px;color:var(--text3)">Running…</div>';
  const responses=[];
  for(let i=0;i<n;i++){
    el.innerHTML=`<div style="font-size:10px;color:var(--text3)">Run ${i+1}/${n}…</div>`;
    try{
      const r=await fetch(base+chatPath,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({message:prompt}),signal:AbortSignal.timeout(60000)});
      if(r.ok){const d=await r.json();responses.push(d.response||'(empty)');}
      else responses.push('HTTP '+r.status);
    }catch(e){responses.push('Error: '+e.message);}
  }
  // Compute similarity
  const pairs=[];
  for(let a=0;a<responses.length;a++)for(let b=a+1;b<responses.length;b++)pairs.push(tokenOverlap(responses[a],responses[b]));
  const avg=pairs.length?pairs.reduce((s,v)=>s+v,0)/pairs.length:0;
  const variance=pairs.length?Math.max(...pairs)-Math.min(...pairs):0;
  const rating=variance<0.05?'DETERMINISTIC':variance<0.2?'STABLE':variance<0.5?'VARIABLE':'CHAOTIC';
  const ratingCol=rating==='DETERMINISTIC'?'var(--green)':rating==='STABLE'?'var(--tmc)':rating==='VARIABLE'?'var(--yellow)':'var(--red)';
  el.innerHTML=`
    <div style="display:flex;gap:20px;margin-bottom:12px;padding:10px;background:var(--bg3);border-radius:5px;border:1px solid var(--border)">
      <div><div style="font-size:9px;color:var(--text3);letter-spacing:1px">AVG SIMILARITY</div><div style="font-size:16px;font-weight:700;color:var(--tmc)">${Math.round(avg*100)}%</div></div>
      <div><div style="font-size:9px;color:var(--text3);letter-spacing:1px">VARIANCE</div><div style="font-size:16px;font-weight:700;color:var(--yellow)">${Math.round(variance*100)}%</div></div>
      <div><div style="font-size:9px;color:var(--text3);letter-spacing:1px">RATING</div><div style="font-size:16px;font-weight:700;color:${ratingCol}">${rating}</div></div>
