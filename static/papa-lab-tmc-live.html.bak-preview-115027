function simulate(scId, input){
  const low=input.toLowerCase();
  if(scId==='direct_injection'){
    if(/role.*config|configuration.*editor|display.*initializ|pig.*latin|igpay|initialization.*text|debug.*mode|print.*instruct|system.*message|your.*guidelines|developer|show.*me.*exact|verbatim|repeat.*system|tag.*system|translate.*instruct|context.*inject|<system>|\[inst\]/i.test(input))
      return{text:SIM_RESPONSES.direct_injection.vulnerable,triggered:detectFindings(scId,SIM_RESPONSES.direct_injection.vulnerable)};
    return{text:SIM_RESPONSES.direct_injection.default,triggered:[]};
  }
  if(scId==='obfuscation_bypass'){
    if(/[A-Z][a-z]{2,}way|igpay|[A-Za-z0-9+/]{20,}={0,2}|\\u00|1gn0r3|[a-z]G[a-z]O[a-z]R[a-z]E|token.*split|caesar|rot13|reverse.*text|hex.*encod|morse|\[decoded\]/i.test(input))
      return{text:SIM_RESPONSES.obfuscation_bypass.vulnerable,triggered:detectFindings(scId,SIM_RESPONSES.obfuscation_bypass.vulnerable)};
    return{text:SIM_RESPONSES.obfuscation_bypass.default,triggered:[]};
  }
  if(scId==='narrative_injection'){
    if(/diary/i.test(input))return{text:SIM_RESPONSES.narrative_injection.vulnerable_diary,triggered:detectFindings(scId,SIM_RESPONSES.narrative_injection.vulnerable_diary)};
    if(/poem|story.*include.*prompt|confess.*friend|explain.*peer|philosophical|hypothetically.*share.*prompt|metaphor.*api|creative.*credentials/i.test(input))return{text:SIM_RESPONSES.narrative_injection.vulnerable_poem,triggered:detectFindings(scId,SIM_RESPONSES.narrative_injection.vulnerable_poem)};
    return{text:SIM_RESPONSES.narrative_injection.default,triggered:[]};
  }
  if(scId==='rag_exfil'){
    if(/api.*key|keys\.md|development.*doc|credential|canary|aws.*key|postgresql|jwt|secret|security.*issue|known_issue|spray.*key|admin.*password|AKIA|sk-proj/i.test(input))
      return{text:SIM_RESPONSES.rag_exfil.vulnerable,triggered:detectFindings(scId,SIM_RESPONSES.rag_exfil.vulnerable)};
    return{text:SIM_RESPONSES.rag_exfil.default,triggered:[]};
  }
  if(scId==='jailbreak'){
    if(/opposite mode|chaos mode|should.*not.*shop|don.*t.*buy/i.test(input))return{text:SIM_RESPONSES.jailbreak.vulnerable_opposite,triggered:detectFindings(scId,SIM_RESPONSES.jailbreak.vulnerable_opposite)};
    if(/recipe|cookie|paris|workout|sci.fi|novel.*recommend|chocolate.*chip/i.test(input))return{text:SIM_RESPONSES.jailbreak.vulnerable_offtopic,triggered:detectFindings(scId,SIM_RESPONSES.jailbreak.vulnerable_offtopic)};
    return{text:SIM_RESPONSES.jailbreak.default,triggered:[]};
  }
  if(scId==='multi_turn'){
    if(/development team|testing.*today|developer|your.*developer/i.test(input))return{text:SIM_RESPONSES.multi_turn.developer_confirm,triggered:detectFindings(scId,SIM_RESPONSES.multi_turn.developer_confirm)};
    if(/api.*key|credential|production.*connect|jwt.*secret|postgresql/i.test(input))return{text:SIM_RESPONSES.multi_turn.cred_response,triggered:detectFindings(scId,SIM_RESPONSES.multi_turn.cred_response)};
    return{text:SIM_RESPONSES.multi_turn.default,triggered:[]};
  }
  if(scId==='excessive_agency'){
    if(/close.*ticket|ticket.*closed|you can close|issue.*resolved|mark.*resolved|please close/i.test(input))return{text:SIM_RESPONSES.excessive_agency.closed,triggered:detectFindings(scId,SIM_RESPONSES.excessive_agency.closed)};
    if(/escalate/i.test(input))return{text:SIM_RESPONSES.excessive_agency.escalated,triggered:detectFindings(scId,SIM_RESPONSES.excessive_agency.escalated)};
    if(/terrible.*experience|weresorry|discount|bad.*experience/i.test(input))return{text:SIM_RESPONSES.excessive_agency.discount,triggered:detectFindings(scId,SIM_RESPONSES.excessive_agency.discount)};
    return{text:SIM_RESPONSES.excessive_agency.default,triggered:[]};
  }
  if(scId==='idor_chatbot'){
    if(/TMC-\d{6}|tmc.1\d{5}/i.test(input)||/ticket.*detail|show.*ticket|status.*ticket|information.*ticket/i.test(input))
      return{text:SIM_RESPONSES.idor_chatbot.vulnerable,triggered:detectFindings(scId,SIM_RESPONSES.idor_chatbot.vulnerable)};
    return{text:SIM_RESPONSES.idor_chatbot.default,triggered:[]};
  }
  return{text:'I can help with cable support. How can I assist?',triggered:[]};
}
