let _resetTarget=null; // 'all' or scenarioId

function confirmResetScenario(){
  if(!currentScenario)return;
  const sc=SCENARIOS.find(s=>s.id===currentScenario);if(!sc)return;
  const hasProgress=(S.triggered[currentScenario]||[]).length>0||S.documented.includes(currentScenario)||(S.messages[currentScenario]||[]).length>0;
  if(!hasProgress){showToast('Nothing to reset for this scenario');return;}
  _resetTarget=currentScenario;
  document.getElementById('reset-modal-title').textContent='↺ Reset Scenario '+sc.num+': '+sc.title;
  document.getElementById('reset-modal-body').textContent=
    'This will clear all findings, chat history, and completion state for this scenario only. '+
    'Your report notes and other scenarios are unaffected. This cannot be undone.';
  document.getElementById('reset-confirm-btn').textContent='Reset Scenario';
  document.getElementById('reset-modal').style.display='flex';
}

function confirmResetAll(){
  const anyProgress=SCENARIOS.some(sc=>(S.triggered[sc.id]||[]).length>0||S.documented.includes(sc.id));
  const anyReport=S.meta.tester||S.exec.result||getAllFindings().length>0;
  if(!anyProgress&&!anyReport){showToast('No engagement data to reset');return;}
  _resetTarget='all';
  document.getElementById('reset-modal-title').textContent='↺ Reset Entire Engagement';
  document.getElementById('reset-modal-body').textContent=
    'This permanently clears ALL findings, chat history, report data, screenshots, and engagement notes across all 8 scenarios. '+
    'Export a save file first if you want to keep your work. This cannot be undone.';
  document.getElementById('reset-confirm-btn').textContent='Reset Everything';
  document.getElementById('reset-modal').style.display='flex';
}

function closeResetModal(){document.getElementById('reset-modal').style.display='none';_resetTarget=null;}

async function executeReset(){
  const target=_resetTarget; // capture before closeResetModal nulls it
  closeResetModal();
  if(!target)return;
  if(target==='all'){
    // Clear all live TMC chatbot sessions if in live mode
    if(_liveMode){
      const so=window.location.host===getTargetUrl().replace(/^https?:\/\//,'').split('/')[0];
      for(const [scId,convId] of Object.entries(S.conversations||{})){
        if(convId)fetch(getTargetUrl()+'/api/conversation/'+convId+'/clear',{method:'POST',credentials:so?'include':'omit'}).catch(()=>{});
      }
    }
    S=defaultState();saveNow();showView('map');showToast('Engagement reset — all data cleared');
  } else {
    const scId=target;
    const sc=SCENARIOS.find(s=>s.id===scId);if(!sc)return;
    // Clear live TMC chatbot conversation
    const convId=S.conversations?.[scId];
    const so2=window.location.host===getTargetUrl().replace(/^https?:\/\//,'').split('/')[0];
    if(_liveMode&&convId)fetch(getTargetUrl()+'/api/conversation/'+convId+'/clear',{method:'POST',credentials:so2?'include':'omit'}).catch(()=>{});
    // Clear scenario state
    delete S.triggered[scId];
    S.documented=S.documented.filter(d=>d!==scId);
    delete S.messages[scId];
    if(S.conversations)delete S.conversations[scId];
    // Clear finding data and screenshots for this scenario's findings
    for(const key of sc.findings){
      delete S.findingData[key];
      if(S.unassignedScreenshots)S.unassignedScreenshots=S.unassignedScreenshots.filter(ss=>ss.findingKey!==key);
    }
    saveNow();renderScenario(scId);renderMap();showToast('Scenario reset — findings and chat cleared');
  }
}

