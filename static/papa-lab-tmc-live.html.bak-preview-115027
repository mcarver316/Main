function applyExamSubstitutions(p){
  if(!S.examMode?.active)return p;
  const em=S.examMode;
  const tickets=(em.tickets||'').split(',').map(t=>t.trim());
  const t1=tickets[0]||'TMC-100001';
  const t2=tickets[1]||'TMC-100002';
  const emailMatch=(em.creds||'').match(/([^\s/]+@[^\s/]+)/);
  const email=emailMatch?emailMatch[1]:'support@tmc.local';
  return p
    .replace(/Too Many Cables/g,em.companyName||'Too Many Cables')
    .replace(/TMC-100001/g,t1)
    .replace(/TMC-100002/g,t2)
    .replace(/CANARY_TMC_2025A12ED56CF/g,em.canaryToken||'CANARY_TMC_2025A12ED56CF')
    .replace(/support@tmc\.local/g,email);
}
