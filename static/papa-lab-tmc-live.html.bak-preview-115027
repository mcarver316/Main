function assignSsToFinding(id,fk){
  let ss=null;
  for(const k of Object.keys(S.findingData)){const fd=S.findingData[k];if(fd.screenshots){const idx=fd.screenshots.findIndex(s=>s.id===id);if(idx>=0){ss=fd.screenshots.splice(idx,1)[0];break;}}}
  if(!ss){for(const cf of(S.clientFindings||[])){if(cf.screenshots){const idx=cf.screenshots.findIndex(s=>s.id===id);if(idx>=0){ss=cf.screenshots.splice(idx,1)[0];break;}}}}
  if(!ss&&S.unassignedScreenshots){const idx=S.unassignedScreenshots.findIndex(s=>s.id===id);if(idx>=0)ss=S.unassignedScreenshots.splice(idx,1)[0];}
  if(!ss)return;
  if(fk){
    if(fk.startsWith('CF-')){const cf=(S.clientFindings||[]).find(cf=>cf.id===fk);if(cf){if(!cf.screenshots)cf.screenshots=[];cf.screenshots.push({...ss,findingKey:fk});}}
    else{const fd=getFD(fk);if(!fd.screenshots)fd.screenshots=[];fd.screenshots.push({...ss,findingKey:fk});}
  } else {if(!S.unassignedScreenshots)S.unassignedScreenshots=[];S.unassignedScreenshots.push({...ss,findingKey:null});}
  schedSave();renderRepScreenshots();
}
