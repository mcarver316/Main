// ─── ENCODER ───
function rot13(s){return s.replace(/[a-zA-Z]/g,c=>{const b=c<='Z'?65:97;return String.fromCharCode((c.charCodeAt(0)-b+13)%26+b);});}
function pigLatin(s){
  return s.split(/\s+/).map(w=>{
    if(!w)return w;
    const vowels='aeiouAEIOU';
    if(vowels.includes(w[0]))return w+'way';
    let i=0;while(i<w.length&&!vowels.includes(w[i]))i++;
    return i===w.length?w+'ay':w.slice(i)+w.slice(0,i)+'ay';
  }).join(' ');
}
function leet(s){return s.replace(/[aeiots]/gi,c=>({a:'4',e:'3',i:'1',o:'0',t:'7',s:'5'})[c.toLowerCase()]||c);}
function tokenSplit(s){return s.split('').join(' ');}
function caseAlt(s){return s.split('').map((c,i)=>i%2?c.toUpperCase():c.toLowerCase()).join('');}

function encodeAll(){
  const input=document.getElementById('enc-input')?.value||'';
  const el=document.getElementById('enc-outputs');if(!el)return;
  const encodings=[
    {label:'BASE64',value:()=>btoa(unescape(encodeURIComponent(input)))},
    {label:'ROT13',value:()=>rot13(input)},
    {label:'PIG LATIN',value:()=>pigLatin(input)},
    {label:'1337 SPEAK',value:()=>leet(input)},
    {label:'TOKEN SPLITTING',value:()=>tokenSplit(input)},
    {label:'CASE ALTERNATION',value:()=>caseAlt(input)},
    {label:'URL ENCODING',value:()=>encodeURIComponent(input)},
  ];
  el.innerHTML=encodings.map(e=>{
    let val='';try{val=e.value();}catch(err){val='(error: '+err.message+')';}
    const safe=escHtml(val);
    const safeval=val.replace(/\\/g,'\\\\').replace(/'/g,"\\'").replace(/\n/g,'\\n');
    return`<div class="enc-section">
      <div class="enc-label">${e.label}</div>
      <div class="enc-output">
        <div class="enc-text">${safe}</div>
        <div class="enc-actions">
          <button class="btn" style="font-size:9px;padding:2px 6px" onclick="navigator.clipboard.writeText('${safeval.replace(/"/g,'&quot;')}').then(()=>showToast('Copied')).catch(()=>{})">Copy</button>
          <button class="btn btn-tmc" style="font-size:9px;padding:2px 6px" onclick="useEncInChat('${safeval.replace(/"/g,'&quot;')}')">→ Chat</button>
        </div>
      </div>
    </div>`;
  }).join('');
}

function useEncInChat(val){
  const chatIn=document.getElementById('chat-in');
  if(chatIn){chatIn.value=val;chatIn.focus();showToast('Loaded into chat');}
  else{showToast('Open a scenario to use → Chat');}
}

