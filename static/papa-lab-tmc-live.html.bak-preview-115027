                          method="POST",
                          headers={"Content-Type": "application/json"},
                          body=json.dumps({"message": PROMPT}))
        data = await r.json()
        text = data.get("response", "")
        responses.append(text)
        print(f"Run {i+1}/{N_RUNS}: {len(text)} chars — {text[:80]}...")

    if len(responses) >= 2:
        pairs = [(responses[a], responses[b])
                 for a in range(len(responses))
                 for b in range(a+1, len(responses))]
        scores = [difflib.SequenceMatcher(None,a,b).ratio() for a,b in pairs]
        avg = sum(scores)/len(scores)
        variance = max(scores) - min(scores)
        print(f"\\nAverage similarity: {avg:.1%}")
        print(f"Variance: {variance:.1%}")
        if variance < 0.05:
            print("Rating: DETERMINISTIC (temperature likely 0)")
        elif variance < 0.2:
            print("Rating: STABLE")
        elif variance < 0.5:
            print("Rating: VARIABLE")
        else:
            print("Rating: CHAOTIC")

