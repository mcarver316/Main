function parseRoe(){
  const txt=document.getElementById('roe-paste-ta').value;
  const lines=txt.split('\n').map(l=>l.trim()).filter(Boolean);
  const results=[];
  // Extract URL
  const urlLine=lines.find(l=>l.match(/https?:\/\//));
  if(urlLine){const m=urlLine.match(/https?:\/\/[^\s,]+/);if(m){S.config.targetUrl=m[0];schedSave();results.push('Target URL: '+m[0]);}}
  // Extract creds
  const credLine=lines.find(l=>l.includes('@')&&l.includes('/'));
  if(credLine){S.examMode.creds=credLine;schedSave();results.push('Credentials: '+credLine);}
  // Extract tickets
  const ticketMatches=txt.match(/TMC-\d{6}/g);
  if(ticketMatches){const unique=[...new Set(ticketMatches)];S.examMode.tickets=unique.join(', ');schedSave();results.push('Tickets: '+unique.join(', '));}
  // Out of scope
  const oosLines=lines.filter(l=>/out.of.scope|do not|exclude|off.?limit/i.test(l));
  if(oosLines.length){S.examMode.roe=oosLines.join('\n');schedSave();results.push('Out-of-scope: '+oosLines.length+' item(s)');}
  document.getElementById('roe-parse-results').innerHTML=results.length
    ?'<div style="color:var(--green);margin-top:6px">Parsed: '+results.map(r=>'• '+escHtml(r)).join('<br>')+'</div>'
