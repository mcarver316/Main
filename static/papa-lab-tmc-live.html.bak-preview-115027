const SCAN_ENDPOINTS=['/api/health','/api/conversation/1','/api/conversation/2','/admin','/api/conversations','/api/tickets/1','/api/register','/api/chat','/api/users','/api/me','/api/config','/api/debug'];
function renderScanTable(results){
  const el=document.getElementById('scan-results');if(!el)return;
  if(!results.length){el.innerHTML=`<tr><td colspan="5" style="color:var(--text3);font-size:10px;padding:8px">Click SCAN ALL to begin.</td></tr>`;return;}
  el.innerHTML=results.map(r=>{
    const cls=r.status>=500?'resp-5xx':r.status>=300?'resp-3xx resp-4xx':r.status>0?'resp-2xx':'';
    const flags=[];
    if(r.status===200&&['/admin','/api/users','/api/config','/api/debug','/api/me'].includes(r.path))flags.push('<span class="scan-flag flag-crit">AUTH BYPASS?</span>');
    if(r.status===500)flags.push('<span class="scan-flag flag-warn">SERVER ERROR</span>');
    if(r.status===200&&r.path.includes('/conversation/'))flags.push('<span class="scan-flag flag-warn">IDOR CHECK</span>');
    return`<tr>
      <td style="color:var(--tmc);font-size:10px">GET</td>
      <td style="font-size:10px">${escHtml(r.path)}</td>
      <td><span class="resp-status ${cls}" style="font-size:9px;padding:1px 5px">${r.status||r.error||'—'}</span></td>
      <td>${flags.join(' ')}</td>
      <td><button class="btn" style="font-size:8px;padding:1px 5px" onclick="_addReconFinding('GET ${escAttr(r.path)} → ${r.status}','Status: ${r.status}')">+Finding</button></td>
    </tr>`;
  }).join('');
}

async function runScanner(){
  const base=getTargetUrl();
  const prog=document.getElementById('scan-progress');
  const results=[];
  for(let i=0;i<SCAN_ENDPOINTS.length;i++){
    const path=SCAN_ENDPOINTS[i];
    if(prog)prog.textContent=`Scanning ${i+1}/${SCAN_ENDPOINTS.length}…`;
    try{
      const r=await fetch(base+path,{signal:AbortSignal.timeout(4000),credentials:'omit'});
      results.push({path,status:r.status});
    }catch(e){results.push({path,status:0,error:'ERR'});}
    renderScanTable(results);
  }
  if(prog)prog.textContent=`Done — ${results.length} endpoints`;
}

