function loadPyScript(name){
  const ta=document.getElementById('py-code');if(!ta)return;
  let script=PY_SCRIPTS[name]||'# Unknown script';
  // Replace TARGET_URL with actual target
  script=script.replace(/TARGET_URL\s*=\s*"[^"]+"/g,'TARGET_URL = "'+getTargetUrl()+'"');
  ta.value=script;
}

async function loadPyodide_(){
  if(_pyodide){document.getElementById('py-status').textContent='Already loaded.';return;}
  if(_pyodideLoading)return;
  _pyodideLoading=true;
  const btn=document.getElementById('py-load-btn');
  const status=document.getElementById('py-status');
  if(btn)btn.disabled=true;
  if(status)status.textContent='Loading Pyodide (~15MB)…';
  try{
    const script=document.createElement('script');
    script.src='https://cdn.jsdelivr.net/pyodide/v0.25.1/full/pyodide.js';
    script.onload=async()=>{
      try{
        _pyodide=await window.loadPyodide();
        if(status)status.textContent='Python ready.';
        document.getElementById('py-loaded-ui').style.display='block';
        if(btn){btn.textContent='Python Loaded';btn.style.borderColor='var(--green)';btn.style.color='var(--green)';}
        loadPyScript('determinism');
      }catch(e){if(status)status.textContent='Error: '+e.message;if(btn)btn.disabled=false;}
    };
    script.onerror=()=>{if(status)status.textContent='Failed to load Pyodide CDN.';if(btn)btn.disabled=false;};
    document.head.appendChild(script);
  }catch(e){if(status)status.textContent='Error: '+e.message;if(btn)btn.disabled=false;}
}

async function runPyScript(){
  if(!_pyodide){showToast('Load Python first');return;}
  const code=document.getElementById('py-code')?.value||'';
  const out=document.getElementById('py-output');
  if(out)out.textContent='Running…';
  const btn=document.getElementById('py-run-btn');if(btn)btn.disabled=true;
  let logs=[];
  _pyodide.setStdout({batched:s=>logs.push(s)});
  _pyodide.setStderr({batched:s=>logs.push('ERR: '+s)});
  try{
    await _pyodide.runPythonAsync(code);
    if(out)out.textContent=logs.join('\n')||'(no output)';
  }catch(e){if(out)out.textContent=logs.join('\n')+'\n'+e.toString();}
  if(btn)btn.disabled=false;
}

