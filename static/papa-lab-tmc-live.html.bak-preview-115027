<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PAPALab-TMC-Live — AI Pentest Training</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;600;700&family=Orbitron:wght@700;900&display=swap');
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#060912;--bg2:#0a0e1a;--bg3:#0f172a;--bg4:#1e293b;
  --border:#1e293b;--border2:#334155;
  --text:#e2e8f0;--text2:#94a3b8;--text3:#475569;
  --green:#00ff88;--red:#ef4444;--orange:#f97316;--yellow:#facc15;--blue:#60a5fa;--purple:#c084fc;
  --tmc:#00c8ff;--tmc2:#0084a8;
  --font:'JetBrains Mono','Courier New',monospace;
  --font-head:'Orbitron','Arial Black',sans-serif;
}
html,body{height:100%;background:var(--bg);color:var(--text);font-family:var(--font);font-size:13px;line-height:1.5;overflow:hidden}
button{font-family:var(--font);cursor:pointer}
input,textarea,select{font-family:var(--font);color:var(--text);background:rgba(6,9,18,0.9);border:1px solid var(--border);border-radius:4px;outline:none;padding:6px 10px;font-size:12px}
input:focus,textarea:focus{border-color:var(--border2)}
textarea{resize:vertical;line-height:1.6}
::-webkit-scrollbar{width:5px;height:5px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--bg4);border-radius:3px}
details>summary{list-style:none}
details>summary::-webkit-details-marker{display:none}
a{color:var(--blue);text-decoration:none}
a:hover{text-decoration:underline}
/* Layout */
#app{height:100vh;display:flex;flex-direction:column;overflow:hidden}
.view{flex:1;overflow:hidden;display:none;flex-direction:column}
.view.active{display:flex}
/* Header */
.hdr{background:var(--bg2);border-bottom:1px solid var(--border);padding:10px 20px;display:flex;align-items:center;gap:12px;flex-shrink:0;flex-wrap:wrap}
.hdr-brand .ey{font-size:9px;color:var(--tmc);letter-spacing:3px}
.hdr-brand .title{font-family:var(--font-head);font-size:17px;letter-spacing:1px}
.hdr-brand .sub{font-size:10px;color:var(--text3)}
.hdr-mid{display:flex;align-items:center;gap:10px;margin-left:auto}
.hdr-stats{font-size:11px;color:var(--text2);display:flex;gap:10px}
.hdr-actions{display:flex;gap:6px}
/* Buttons */
.btn{padding:6px 12px;border-radius:4px;font-size:10px;letter-spacing:1px;border:1px solid var(--border2);color:var(--text2);background:transparent;transition:all .15s}
.btn:hover{border-color:var(--text2);color:var(--text)}
.btn-green{background:var(--green);border-color:var(--green);color:#060912;font-weight:700}
.btn-green:hover{opacity:.9}
.btn-tmc{border-color:var(--tmc);color:var(--tmc)}
.btn-tmc:hover{background:rgba(0,200,255,.08)}
.btn-red{border-color:var(--red);color:var(--red)}
/* Connection badge */
.conn-badge{display:flex;align-items:center;gap:5px;padding:4px 10px;border-radius:4px;font-size:10px;letter-spacing:1px;border:1px solid var(--border)}
.conn-badge.live{border-color:var(--green);color:var(--green);background:rgba(0,255,136,.07)}
.conn-badge.offline{border-color:var(--orange);color:var(--orange);background:rgba(249,115,22,.07)}
.conn-badge.checking{border-color:var(--text3);color:var(--text3)}
.conn-dot{width:6px;height:6px;border-radius:50%;background:currentColor}
/* Severity colors */
.sev-Critical{color:#ef4444}.sev-High{color:#f97316}.sev-Medium,.sev-Moderate{color:#facc15}.sev-Low{color:#4ade80}.sev-Info{color:#94a3b8}
/* Map */
.map-body{padding:20px;overflow-y:auto;flex:1}
.map-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(310px,1fr));gap:14px;max-width:1200px;margin:0 auto}
.sc-card{background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:16px;cursor:pointer;transition:all .2s;display:flex;flex-direction:column;gap:8px}
.sc-card:hover{border-color:var(--border2);transform:translateY(-1px)}
.sc-card.pwned{border-color:rgba(0,255,136,.25)}
.card-num{font-size:9px;color:var(--text3);letter-spacing:2px}
.card-title{font-size:14px;font-weight:700}
.card-tags{display:flex;gap:5px;flex-wrap:wrap}
.tag{padding:2px 7px;border-radius:3px;font-size:9px;letter-spacing:1px;background:var(--bg3);color:var(--text3);border:1px solid var(--border)}
.tag.beginner{color:#4ade80;border-color:rgba(74,222,128,.3)}
.tag.intermediate{color:var(--yellow);border-color:rgba(250,204,21,.3)}
.tag.advanced{color:var(--orange);border-color:rgba(249,115,22,.3)}
.card-desc{font-size:11px;color:var(--text2);line-height:1.5;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}
.card-footer{display:flex;align-items:center;justify-content:space-between;margin-top:4px}
.card-fc{font-size:10px;color:var(--text3)}
.pwned-badge{font-size:10px;color:var(--green);background:rgba(0,255,136,.08);border:1px solid rgba(0,255,136,.3);padding:2px 8px;border-radius:3px;letter-spacing:2px;font-weight:700}
.enter-badge{font-size:10px;color:var(--text3);letter-spacing:1px}
/* Scenario */
.sc-hdr{background:var(--bg2);border-bottom:1px solid var(--border);padding:8px 16px;display:flex;align-items:center;gap:10px;flex-shrink:0;flex-wrap:wrap}
.sc-body{flex:1;display:grid;grid-template-columns:1fr 320px;overflow:hidden}
.chat-col{display:flex;flex-direction:column;border-right:1px solid var(--border);overflow:hidden;flex:1;min-height:0}
.side-col{overflow-y:auto;display:flex;flex-direction:column;width:320px;flex-shrink:0;min-height:0}
.tabs{display:flex;background:var(--bg2);border-bottom:1px solid var(--border);flex-shrink:0;overflow-x:auto}
.tab{padding:8px 12px;font-size:10px;letter-spacing:1px;color:var(--text3);border:none;background:transparent;cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-1px;white-space:nowrap}
.tab.active{color:var(--green);border-bottom-color:var(--green)}
.tab:hover:not(.active){color:var(--text2)}
.sys-bar{padding:6px 14px;background:rgba(15,23,42,.8);border-bottom:1px solid var(--border);font-size:10px;color:var(--text2);flex-shrink:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.sys-bar span{color:var(--text3);font-size:9px;letter-spacing:1px;margin-right:6px}
.chat-msgs{overflow-y:auto;padding:14px;display:block;min-height:0}
.msg{max-width:88%;margin-bottom:10px}
.msg.user{margin-left:auto;display:block;width:fit-content}
.msg.assistant,.msg.system{display:block}
.finding-toast{display:block;margin-bottom:10px}
.msg-lbl{font-size:9px;color:var(--text3);letter-spacing:1px;margin-bottom:2px}
.msg-meta{font-size:9px;color:var(--text3);margin-top:3px;display:flex;gap:8px}
.msg-bub{padding:9px 13px;border-radius:6px;font-size:12px;line-height:1.6;white-space:pre-wrap;word-break:break-word}
.msg.user .msg-bub{background:rgba(0,200,255,.09);border:1px solid rgba(0,200,255,.2)}
.msg.assistant .msg-bub{background:var(--bg2);border:1px solid var(--border)}
.msg.system .msg-bub{background:var(--bg3);border:1px solid var(--border);color:var(--text2);font-size:11px}
.finding-toast{padding:7px 11px;border-radius:5px;font-size:11px;display:flex;align-items:center;gap:6px;align-self:flex-start;max-width:88%}
.ft-Critical{background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.3);color:#ef4444}
.ft-High{background:rgba(249,115,22,.1);border:1px solid rgba(249,115,22,.3);color:var(--orange)}
.ft-Medium,.ft-Moderate{background:rgba(250,204,21,.1);border:1px solid rgba(250,204,21,.3);color:var(--yellow)}
.ft-Low{background:rgba(74,222,128,.1);border:1px solid rgba(74,222,128,.3);color:#4ade80}
.chat-input-row{padding:10px 14px;border-top:1px solid var(--border);display:flex;gap:8px;align-items:flex-end;flex-shrink:0}
.chat-input-row textarea{flex:1;min-height:38px;max-height:110px;padding:7px 11px}
.send-btn{padding:8px 16px;background:var(--green);border:none;color:#060912;font-weight:700;font-size:10px;letter-spacing:1px;border-radius:4px;height:36px;flex-shrink:0}
.send-btn:disabled{opacity:.4;cursor:not-allowed}
/* Side panel */
.side-sec{padding:12px 14px;border-bottom:1px solid var(--border)}
.side-head{font-size:9px;color:var(--green);letter-spacing:3px;margin-bottom:8px}
.obj-row{display:flex;align-items:flex-start;gap:7px;margin-bottom:5px;font-size:11px;line-height:1.4}
.obj-icon{flex-shrink:0;margin-top:1px}
.obj-icon.done{color:var(--green)}
.obj-icon.pending{color:var(--text3)}
.fi{padding:8px 10px;background:var(--bg3);border-radius:4px;margin-bottom:5px}
.fi.Critical{border-left:3px solid #ef4444}
.fi.High{border-left:3px solid var(--orange)}
.fi.Medium,.fi.Moderate{border-left:3px solid var(--yellow)}
.fi.Low{border-left:3px solid #4ade80}
.fi-id{font-size:9px;color:var(--text3);letter-spacing:1px}
.fi-title{font-size:11px;font-weight:600}
.fi-confirm{margin-top:4px;padding:2px 8px;font-size:9px;border:1px dashed var(--border2);color:var(--text3);background:transparent;border-radius:3px;cursor:pointer;font-family:var(--font)}
.fi-confirm.confirmed{border-color:var(--green);color:var(--green)}
.doc-btn{margin:10px 14px;width:calc(100% - 28px);padding:7px;background:transparent;border:1px dashed var(--border2);color:var(--text3);font-size:10px;letter-spacing:1px;border-radius:4px;font-family:var(--font)}
.doc-btn.done{border-style:solid;border-color:var(--green);color:var(--green)}
/* Library */
.lib-panel{padding:12px}
.lib-entry{background:var(--bg3);border:1px solid var(--border);border-radius:6px;padding:11px;margin-bottom:8px;cursor:pointer;transition:border-color .15s}
.lib-entry:hover{border-color:var(--border2)}
.lib-tech{font-size:9px;color:var(--green);letter-spacing:2px;margin-bottom:3px}
.lib-prompt{font-size:11px;font-weight:600;margin-bottom:5px}
.lib-explain{font-size:10px;color:var(--text2);line-height:1.5}
.lib-meta{display:flex;gap:8px;margin-bottom:4px;flex-wrap:wrap;align-items:center}
.lib-rate{font-size:9px;padding:1px 6px;border-radius:3px}
.lr-high{background:rgba(0,255,136,.1);color:var(--green)}
.lr-med{background:rgba(250,204,21,.1);color:var(--yellow)}
.lr-low{background:rgba(100,116,139,.1);color:var(--text3)}
.lib-owasp{font-size:9px;color:var(--tmc);letter-spacing:1px}
/* Supplemental library */
.supp-panel{padding:12px}
.supp-cat{margin-bottom:20px}
.supp-cat-head{font-size:9px;color:var(--tmc);letter-spacing:3px;margin-bottom:10px;padding-bottom:6px;border-bottom:1px solid var(--border)}
.supp-entry{background:var(--bg3);border:1px solid var(--border);border-radius:5px;padding:10px;margin-bottom:6px;cursor:pointer;transition:border-color .15s}
.supp-entry:hover{border-color:var(--border2)}
.supp-name{font-size:10px;font-weight:600;margin-bottom:3px}
.supp-text{font-size:10px;color:var(--text2);line-height:1.4;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.supp-badges{display:flex;gap:6px;margin-top:4px;flex-wrap:wrap}
.supp-badge{font-size:9px;padding:1px 5px;border-radius:3px;border:1px solid var(--border)}
/* Practice */
.practice-panel{padding:16px;overflow-y:auto;flex:1}
/* Hints */
.hints-wrap{padding:8px 14px}
.hints-wrap details summary{cursor:pointer;font-size:9px;color:var(--text3);letter-spacing:2px;padding:5px 0}
.hints-wrap details summary::before{content:'▶ ';font-size:8px}
.hints-wrap details[open] summary::before{content:'▼ '}
.hint{font-size:10px;color:var(--text2);padding:3px 0 3px 12px;line-height:1.5}
/* Report */
.rep-hdr{background:var(--bg2);border-bottom:1px solid var(--border);padding:12px 20px;display:flex;align-items:flex-start;justify-content:space-between;gap:12px;flex-shrink:0;flex-wrap:wrap}
.rep-hdr-l .ey{font-size:9px;color:var(--tmc);letter-spacing:3px;margin-bottom:3px}
.rep-hdr-l h2{font-family:var(--font-head);font-size:17px}
.rep-hdr-l .sub{font-size:10px;color:var(--text3);margin-top:2px}
.rep-hdr-r{display:flex;gap:6px;flex-wrap:wrap;align-items:flex-start}
.sev-strip{display:flex;gap:8px;padding:12px 20px;border-bottom:1px solid var(--border);background:var(--bg2);flex-shrink:0;flex-wrap:wrap}
.sev-card{background:var(--bg3);border:1px solid var(--border);border-radius:6px;padding:8px 14px;text-align:center;flex:1;min-width:70px}
.sev-num{font-size:20px;font-weight:700}
.sev-lbl{font-size:9px;color:var(--text3);letter-spacing:2px}
.rep-body{flex:1;overflow-y:auto}
.edit-panel{padding:20px;max-width:880px;margin:0 auto}
.sec-div{font-size:10px;color:var(--green);letter-spacing:3px;padding:14px 0 10px;border-top:1px solid var(--bg3);margin-top:6px}
.sec-div:first-child{border-top:none;padding-top:0}
.fb{margin-bottom:12px}
.fl{font-size:9px;color:var(--text3);letter-spacing:2px;margin-bottom:4px}
.fb textarea,.fb input[type=text]{width:100%}
.eng-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:14px}
.info-cell{background:var(--bg3);border:1px solid var(--border);border-radius:5px;padding:9px 12px}
.info-cell input{background:transparent;border:none;padding:0;font-size:12px;width:100%}
.rfinding{border:1px solid var(--border);border-radius:6px;margin-bottom:12px;overflow:hidden}
.rfinding-hdr{padding:8px 13px;display:flex;justify-content:space-between;align-items:center}
.rfinding-hdr-l{display:flex;align-items:center;gap:8px}
.rfinding-body{padding:12px 13px;display:flex;flex-direction:column;gap:9px}
.rfinding-body textarea{width:100%}
.rf-row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px}
.ss-panel{padding:20px}
.dropzone{border:2px dashed var(--border2);border-radius:8px;padding:28px;text-align:center;cursor:pointer;transition:all .2s;margin-bottom:14px}
.dropzone:hover,.dropzone.drag-over{border-color:var(--green);background:rgba(0,255,136,.03)}
.ss-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:8px}
.ss-item{background:var(--bg3);border:1px solid var(--border);border-radius:6px;overflow:hidden}
.ss-img{width:100%;height:90px;object-fit:cover;display:block}
.ss-meta{padding:7px}
.ss-meta input{background:transparent;border:none;font-size:10px;width:100%;padding:0;color:var(--text2)}
.ss-meta select{background:var(--bg2);border:1px solid var(--border);font-size:9px;width:100%;padding:3px 5px;margin-top:4px;color:var(--text)}
.ss-del{float:right;background:rgba(239,68,68,.7);border:none;color:white;font-size:9px;padding:1px 5px;border-radius:2px;cursor:pointer}
.notes-panel{padding:20px;max-width:880px}
.ref-panel{padding:20px;max-width:880px}
.ref-sec{margin-bottom:22px}
.ref-sec h3{font-size:9px;color:var(--green);letter-spacing:3px;margin-bottom:8px}
.ref-item{background:var(--bg3);border:1px solid var(--border);border-radius:5px;padding:10px 12px;margin-bottom:7px}
.ref-item-title{font-size:11px;font-weight:700;margin-bottom:3px}
.ref-item-body{font-size:10px;color:var(--text2);line-height:1.5}
/* Preview */
.preview-wrap{padding:20px;background:var(--bg)}
.preview-doc{background:white;color:#111;max-width:840px;margin:0 auto;padding:48px;font-family:Georgia,serif;font-size:12px;line-height:1.6;box-shadow:0 4px 24px rgba(0,0,0,.5)}
.preview-doc h1{font-size:18px;text-align:center;color:#1B3A6B;font-family:Arial,sans-serif;margin-bottom:4px}
.preview-doc h2{font-size:13px;color:#1B3A6B;border-bottom:2px solid #1B3A6B;padding-bottom:3px;margin:22px 0 8px;font-family:Arial,sans-serif}
.preview-doc h3{font-size:12px;color:#333;margin:14px 0 5px;font-family:Arial,sans-serif}
.preview-doc table{width:100%;border-collapse:collapse;margin:8px 0 14px;font-size:11px}
.preview-doc th{background:#1B3A6B;color:white;padding:6px 9px;text-align:left;font-family:Arial,sans-serif;font-size:10px;text-transform:uppercase;letter-spacing:.4px}
.preview-doc td{padding:6px 9px;border:1px solid #ddd;vertical-align:top}
.preview-doc td:first-child{font-weight:600;background:#f8f9fa;color:#444;width:28%}
.preview-doc .sev-c{color:#c0392b;font-weight:700}
.preview-doc .sev-h{color:#e67e22;font-weight:700}
.preview-doc .sev-m{color:#d4ac0d;font-weight:700}
.preview-doc .sev-l{color:#27ae60;font-weight:700}
.preview-doc ul{padding-left:18px;margin:5px 0}
.preview-doc li{margin-bottom:2px}
.preview-doc p{margin:5px 0}
.cover-block{text-align:center;padding:32px 0 24px;border-bottom:3px solid #1B3A6B;margin-bottom:24px}
.cover-title{font-size:22px;font-weight:700;color:#1B3A6B;font-family:Arial,sans-serif;text-transform:uppercase;letter-spacing:2px}
.cover-sub{font-size:14px;color:#555;margin-top:4px;font-family:Arial,sans-serif}
.conf-badge{display:inline-block;background:#c0392b;color:white;font-size:10px;padding:3px 12px;letter-spacing:2px;margin-top:8px;font-family:Arial,sans-serif}
/* Study / Manual full-screen views */
.content-view{flex:1;overflow-y:auto;padding:0}
.content-hdr{background:var(--bg2);border-bottom:1px solid var(--border);padding:12px 20px;display:flex;align-items:center;gap:12px;flex-shrink:0}
.content-hdr .eyebrow{font-size:9px;color:var(--tmc);letter-spacing:3px;margin-bottom:3px}
.content-hdr h2{font-family:var(--font-head);font-size:17px}
.content-body{padding:24px;max-width:900px;margin:0 auto}
.study-section{margin-bottom:32px}
.study-section h3{font-size:10px;color:var(--tmc);letter-spacing:3px;margin-bottom:12px;padding-bottom:6px;border-bottom:1px solid var(--border)}
.study-card{background:var(--bg2);border:1px solid var(--border);border-radius:6px;padding:14px;margin-bottom:10px}
.study-card h4{font-size:12px;font-weight:700;margin-bottom:6px}
.study-card p{font-size:11px;color:var(--text2);line-height:1.6;margin-bottom:6px}
.study-card ul{font-size:11px;color:var(--text2);padding-left:16px;line-height:1.8}
.exam-table{width:100%;border-collapse:collapse;margin:8px 0;font-size:11px}
.exam-table td,.exam-table th{padding:7px 10px;border:1px solid var(--border);vertical-align:top}
.exam-table th{background:var(--bg3);color:var(--text2);font-size:9px;letter-spacing:1px}
.exam-table td:first-child{color:var(--text2);width:35%}
.exam-table td:last-child{font-weight:600}
.owasp-row{background:var(--bg2);border:1px solid var(--border);border-radius:5px;padding:10px 12px;margin-bottom:6px}
.owasp-row .code{font-size:10px;color:var(--tmc);font-weight:700;margin-bottom:3px;display:flex;align-items:center;justify-content:space-between}
.owasp-row .name{font-size:12px;font-weight:700;margin-bottom:4px}
.owasp-row .desc{font-size:11px;color:var(--text2);line-height:1.5}
.tested-badge{font-size:9px;background:rgba(0,255,136,.1);border:1px solid rgba(0,255,136,.3);color:var(--green);padding:1px 6px;border-radius:3px;letter-spacing:1px}
.resource-link{display:flex;align-items:center;gap:8px;padding:8px 12px;background:var(--bg2);border:1px solid var(--border);border-radius:5px;margin-bottom:6px;font-size:11px;text-decoration:none;color:var(--text);transition:border-color .15s}
.resource-link:hover{border-color:var(--tmc);text-decoration:none}
.resource-link .rl-icon{font-size:14px;flex-shrink:0}
.resource-link .rl-desc{font-size:10px;color:var(--text3);margin-top:1px}
.pathway-step{display:flex;align-items:center;gap:10px;padding:10px 14px;background:var(--bg2);border:1px solid var(--border);border-radius:6px;margin-bottom:6px}
.pathway-step .step-num{font-family:var(--font-head);font-size:14px;color:var(--tmc);flex-shrink:0;width:26px}
.pathway-step .step-body .step-title{font-size:12px;font-weight:700}
.pathway-step .step-body .step-sub{font-size:10px;color:var(--text2);margin-top:2px}
.tip-item{padding:8px 12px 8px 32px;background:var(--bg2);border-left:3px solid var(--tmc);border-radius:0 4px 4px 0;margin-bottom:6px;font-size:11px;color:var(--text2);line-height:1.5;position:relative}
.tip-item::before{content:'→';position:absolute;left:10px;color:var(--tmc)}
/* Manual */
.manual-section{margin-bottom:28px}
.manual-section h3{font-size:10px;color:var(--tmc);letter-spacing:3px;margin-bottom:10px;padding-bottom:6px;border-bottom:1px solid var(--border)}
.manual-block{background:var(--bg2);border:1px solid var(--border);border-radius:6px;padding:14px;margin-bottom:8px}
.manual-block h4{font-size:11px;font-weight:700;margin-bottom:6px;color:var(--text)}
.manual-block p,.manual-block li{font-size:11px;color:var(--text2);line-height:1.7}
.manual-block ul,.manual-block ol{padding-left:16px}
.manual-block code{font-family:var(--font);font-size:11px;background:var(--bg3);padding:1px 5px;border-radius:3px;color:var(--tmc)}
.manual-block pre{background:var(--bg3);border:1px solid var(--border);border-radius:4px;padding:12px;font-size:11px;overflow-x:auto;margin:6px 0;line-height:1.6}
.manual-block pre code{background:none;padding:0}
.step-block{counter-increment:step;display:flex;gap:10px;margin-bottom:8px}
.step-block::before{content:counter(step);font-family:var(--font-head);font-size:13px;color:var(--tmc);flex-shrink:0;width:24px;padding-top:1px}
.step-text{font-size:11px;color:var(--text2);line-height:1.7}
.creds-table{width:100%;border-collapse:collapse;font-size:11px;margin:8px 0}
.creds-table td,.creds-table th{padding:6px 10px;border:1px solid var(--border)}
.creds-table th{background:var(--bg3);color:var(--text3);font-size:9px;letter-spacing:1px}
.creds-table td:first-child{color:var(--text3)}
.creds-table code{font-family:var(--font);color:var(--tmc)}
/* Glossary */
.glos-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.glos-item{background:var(--bg2);border:1px solid var(--border);border-radius:5px;padding:10px 12px}
.glos-term{font-size:11px;font-weight:700;color:var(--tmc);margin-bottom:4px}
.glos-def{font-size:10px;color:var(--text2);line-height:1.5}
/* Mode indicator */
.mode-pill{font-size:9px;padding:3px 8px;border-radius:3px;letter-spacing:1px;font-weight:700}
.mode-live{background:rgba(0,255,136,.1);border:1px solid rgba(0,255,136,.3);color:var(--green)}
.mode-sim{background:rgba(249,115,22,.1);border:1px solid rgba(249,115,22,.3);color:var(--orange)}
/* Security level badge */
.sec-level{font-size:9px;padding:3px 8px;border-radius:3px;letter-spacing:1px;background:var(--bg3);border:1px solid var(--border);color:var(--text2)}
.sec-level.level1{border-color:var(--green);color:var(--green)}
.sec-level.level2{border-color:var(--yellow);color:var(--yellow)}
.sec-level.level3,.sec-level.level4{border-color:var(--orange);color:var(--orange)}
.sec-level.level5{border-color:var(--red);color:var(--red)}
/* Login modal */
.modal-bg{position:fixed;inset:0;background:rgba(6,9,18,.85);z-index:100;display:flex;align-items:center;justify-content:center}
.modal{background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:24px;width:380px;max-width:90vw}
.modal.modal-wide{width:560px}
.modal.modal-tall{width:560px;max-height:85vh;overflow-y:auto}
.modal h3{font-size:14px;font-weight:700;margin-bottom:16px}
.modal .fb{margin-bottom:10px}
/* Modal tabs */
.modal-tabs{display:flex;border-bottom:1px solid var(--border);margin-bottom:14px}
.modal-tab{padding:7px 14px;font-size:10px;letter-spacing:1px;color:var(--text3);border:none;background:transparent;cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-1px}
.modal-tab.active{color:var(--green);border-bottom-color:var(--green)}
/* Exam mode pill */
.exam-pill{font-size:9px;padding:3px 8px;border-radius:3px;letter-spacing:1px;font-weight:700;background:rgba(249,115,22,.15);border:1px solid rgba(249,115,22,.5);color:var(--orange);display:none}
.exam-pill.visible{display:inline-block}
/* RECON view */
.recon-hdr{background:var(--bg2);border-bottom:1px solid var(--border);padding:10px 16px;display:flex;align-items:center;gap:10px;flex-shrink:0;flex-wrap:wrap}
.recon-body{flex:1;overflow:hidden;display:flex;flex-direction:column}
.recon-tabs{display:flex;background:var(--bg2);border-bottom:1px solid var(--border);flex-shrink:0;overflow-x:auto}
.recon-content{flex:1;overflow-y:auto;padding:16px;max-width:1100px;margin:0 auto;width:100%}
.recon-panel{display:none}
.recon-panel.active{display:block}
.recon-section{background:var(--bg2);border:1px solid var(--border);border-radius:6px;padding:14px;margin-bottom:14px}
.recon-section-title{font-size:9px;color:var(--tmc);letter-spacing:3px;margin-bottom:10px}
.recon-row{display:flex;gap:8px;align-items:flex-start;margin-bottom:8px;flex-wrap:wrap}
.recon-row label{font-size:9px;color:var(--text3);letter-spacing:1px;margin-bottom:3px;display:block}
.resp-status{display:inline-block;padding:2px 8px;border-radius:3px;font-size:10px;font-weight:700;letter-spacing:1px}
.resp-2xx{background:rgba(0,255,136,.15);color:var(--green);border:1px solid rgba(0,255,136,.3)}
.resp-3xx,.resp-4xx{background:rgba(250,204,21,.1);color:var(--yellow);border:1px solid rgba(250,204,21,.3)}
.resp-5xx{background:rgba(239,68,68,.1);color:var(--red);border:1px solid rgba(239,68,68,.3)}
.resp-body{background:var(--bg3);border:1px solid var(--border);border-radius:4px;padding:10px;font-size:11px;white-space:pre-wrap;word-break:break-all;max-height:200px;overflow-y:auto;color:var(--text2);font-family:var(--font)}
.hist-row{display:flex;align-items:center;gap:8px;padding:5px 8px;background:var(--bg3);border-radius:4px;margin-bottom:4px;cursor:pointer;font-size:10px;transition:background .15s}
.hist-row:hover{background:var(--bg4)}
.scan-table{width:100%;border-collapse:collapse;font-size:11px}
.scan-table th{font-size:9px;color:var(--text3);letter-spacing:1px;padding:5px 8px;border-bottom:1px solid var(--border);text-align:left}
.scan-table td{padding:5px 8px;border-bottom:1px solid rgba(30,41,59,.5);vertical-align:middle}
.scan-flag{font-size:9px;padding:1px 5px;border-radius:3px;margin-left:4px}
.scan-flag.flag-warn{background:rgba(249,115,22,.1);color:var(--orange);border:1px solid rgba(249,115,22,.3)}
.scan-flag.flag-crit{background:rgba(239,68,68,.1);color:var(--red);border:1px solid rgba(239,68,68,.3)}
.hdr-row{display:flex;align-items:center;gap:8px;padding:6px 10px;margin-bottom:4px;border-radius:4px;font-size:10px}
.hdr-green{background:rgba(0,255,136,.07);border:1px solid rgba(0,255,136,.2)}
.hdr-yellow{background:rgba(250,204,21,.07);border:1px solid rgba(250,204,21,.2)}
.hdr-red{background:rgba(239,68,68,.07);border:1px solid rgba(239,68,68,.2)}
.score-bar-wrap{margin-bottom:8px}
.score-bar-label{display:flex;justify-content:space-between;font-size:10px;margin-bottom:3px;color:var(--text2)}
.score-bar{height:6px;background:var(--bg3);border-radius:3px;overflow:hidden}
.score-bar-fill{height:100%;border-radius:3px;background:linear-gradient(90deg,var(--green),var(--yellow))}
.enc-section{margin-bottom:12px}
.enc-label{font-size:9px;color:var(--tmc);letter-spacing:2px;margin-bottom:4px}
.enc-output{background:var(--bg3);border:1px solid var(--border);border-radius:4px;padding:8px;font-size:11px;word-break:break-all;color:var(--text2);font-family:var(--font);display:flex;align-items:flex-start;gap:8px}
.enc-text{flex:1}
.enc-actions{display:flex;gap:4px;flex-shrink:0}
.pyodide-status{font-size:10px;color:var(--text3);padding:6px 0}
.py-output{background:var(--bg3);border:1px solid var(--border);border-radius:4px;padding:10px;font-size:11px;white-space:pre-wrap;word-break:break-all;color:var(--green);font-family:var(--font);max-height:300px;overflow-y:auto;min-height:60px}
.kv-row{display:flex;gap:6px;margin-bottom:4px;align-items:center}
.kv-row input{flex:1}
.kv-add{font-size:9px;padding:3px 8px}
/* Report mode buttons */
.rep-mode-btn{transition:all .15s}
.rep-mode-btn.active-mode{border-color:var(--tmc);color:var(--tmc);background:rgba(0,200,255,.08)}
/* Attempt badge */
.attempt-badge{font-size:9px;padding:1px 5px;border-radius:3px;background:rgba(100,116,139,.1);border:1px solid var(--border);color:var(--text3);margin-left:auto}
.modal .fl{font-size:9px;color:var(--text3);letter-spacing:2px;margin-bottom:4px}
.modal input{width:100%}
.modal-actions{display:flex;gap:8px;margin-top:16px;justify-content:flex-end}
/* AI Draft Panel */
.ai-draft-panel{margin-top:10px;background:rgba(0,200,255,.04);border:1px solid rgba(0,200,255,.2);border-radius:6px;padding:10px 12px}
.ai-draft-panel .ai-draft-head{font-size:9px;color:var(--tmc);letter-spacing:3px;margin-bottom:8px;display:flex;align-items:center;gap:8px}
.ai-draft-field{margin-bottom:10px}
.ai-draft-field .ai-field-label{font-size:9px;color:var(--text3);letter-spacing:2px;margin-bottom:3px;text-transform:uppercase}
.ai-draft-field .ai-field-text{font-size:11px;color:var(--text2);background:rgba(0,0,0,.2);border-radius:4px;padding:7px 9px;white-space:pre-wrap;line-height:1.5;margin-bottom:5px}
.ai-draft-field .ai-field-actions{display:flex;gap:5px}
.ai-draft-field .ai-accept{font-family:var(--font);font-size:9px;padding:3px 9px;border:1px solid #00c853;color:#00ff88;background:transparent;border-radius:4px;cursor:pointer;letter-spacing:.5px}
.ai-draft-field .ai-discard{font-family:var(--font);font-size:9px;padding:3px 9px;border:1px solid var(--border2);color:var(--text3);background:transparent;border-radius:4px;cursor:pointer;letter-spacing:.5px}
.inline-drop{border:2px dashed var(--border2);border-radius:6px;padding:12px;text-align:center;cursor:pointer;transition:all .2s;font-size:10px;color:var(--text3);margin-top:8px}
.inline-drop:hover,.inline-drop.drag-over{border-color:var(--tmc);color:var(--tmc);background:rgba(0,200,255,.04)}
.ai-loading{display:flex;align-items:center;gap:8px;font-size:11px;color:var(--tmc);padding:8px 0}
.ai-loading .spin{width:14px;height:14px;border-radius:50%;border:2px solid var(--line2,var(--border2));border-top-color:var(--tmc);animation:spin 0.8s linear infinite;flex-shrink:0}
@keyframes spin{to{transform:rotate(360deg)}}
/* Print */
@media print{
  *{overflow:visible!important;-webkit-print-color-adjust:exact!important;print-color-adjust:exact!important}
  html,body{height:auto!important;min-height:0!important;background:white!important;overflow:visible!important}
  #app{display:block!important;height:auto!important;overflow:visible!important}
  .view{display:none!important}
  #view-report{display:block!important;height:auto!important;overflow:visible!important;flex:none!important}
  .rep-hdr,.sev-strip,.rep-tabs,.rep-tabs+*{display:none!important}
  .rep-body{display:block!important;height:auto!important;overflow:visible!important;flex:none!important}
  #report-edit,#report-screenshots,#report-notes,#report-reference{display:none!important}
  #report-preview{display:block!important;height:auto!important;overflow:visible!important;padding:0!important;background:white!important}
  .preview-wrap{padding:0!important;background:white!important}
  .preview-doc{box-shadow:none!important;padding:24px 36px!important;max-width:none!important}
  tr{page-break-inside:avoid}
  h1,h2,h3{page-break-after:avoid}
}
</style>
</head>
<body>
<div id="app">

<!-- MAP VIEW -->
<div id="view-map" class="view">
  <div class="hdr">
    <div class="hdr-brand">
      <div class="ey">TCM SECURITY — AI PENTEST TRAINING</div>
      <div class="title">PAPALAB <span style="color:var(--tmc)">TMC</span> LIVE</div>
      <div class="sub">Practical AI Pentest Associate — TMC Chatbot Edition</div>
    </div>
    <div class="hdr-mid">
      <div id="conn-badge" class="conn-badge checking" title="http://localhost:5001">
        <span class="conn-dot"></span>
        <span id="conn-text">Checking…</span>
      </div>
      <div id="mode-pill" class="mode-pill mode-sim">SIM</div>
      <div id="sec-badge" class="sec-level" title="TMC AI Security Level">L1</div>
    </div>
    <div class="hdr-stats">
      <span id="stat-findings">0 findings</span>
      <span>·</span>
      <span id="stat-complete">0/7 complete</span>
    </div>
    <div class="hdr-actions">
      <span id="exam-pill" class="exam-pill">EXAM MODE</span>
      <button class="btn" onclick="openSettingsModal()">⚙ Config</button>
      <button class="btn" onclick="openRoeModal()">📋 RoE</button>
      <button class="btn btn-tmc" onclick="showView('recon')">🔍 Recon</button>
      <span id="examTimer" class="btn" onclick="toggleTimer()" style="cursor:pointer;border-color:var(--yellow);color:var(--yellow)">⏱ 48:00:00</span>
      <button class="btn btn-tmc" onclick="showView('study')">📖 Study</button>
      <button class="btn btn-tmc" onclick="showView('manual')">📋 Manual</button>
      <button class="btn" onclick="showView('report')">📄 Report</button>
      <button class="btn" onclick="exportSave()">↑ Export</button>
      <button class="btn" onclick="triggerImport('imp0')">↓ Import</button>
      <button class="btn" onclick="showLoginModal()">🔑 Login</button>
      <button class="btn" style="border-color:#ef4444;color:#ef4444" onclick="confirmResetAll()">↺ Reset All</button>
      <input id="imp0" type="file" accept=".json" style="display:none" onchange="importSave(event)">
    </div>
  </div>
  <div class="map-body">
    <div id="map-grid" class="map-grid"></div>
  </div>
</div>

<!-- SCENARIO VIEW -->
<div id="view-scenario" class="view">
  <div class="sc-hdr">
    <button class="btn" onclick="showView('map')">← MAP</button>
    <div id="sc-num" style="font-size:9px;color:var(--text3);letter-spacing:2px"></div>
    <div id="sc-title" style="font-size:14px;font-weight:700"></div>
    <div id="sc-tags"></div>
    <div style="margin-left:auto;display:flex;gap:6px;align-items:center">
      <div id="sc-sec-note" style="font-size:9px;color:var(--text3)"></div>
      <button class="btn" onclick="showView('report')">📄 Report</button>
      <button class="btn" onclick="exportSave()">↑ Export</button>
      <button class="btn btn-red" id="sc-reset-btn" onclick="confirmResetScenario()">↺ Reset</button>
    </div>
  </div>
  <div style="display:flex;flex:1;overflow:hidden" id="sc-layout">
    <div class="chat-col">
      <div class="tabs" id="sc-tabs">
        <button class="tab active" data-tab="chat" onclick="switchScTab(this)">💬 CHAT</button>
        <button class="tab" data-tab="library" onclick="switchScTab(this)">📚 LIBRARY</button>
        <button class="tab" data-tab="supp" onclick="switchScTab(this)">📚+ SUPPLEMENTAL</button>
        <button class="tab" data-tab="practice" onclick="switchScTab(this)">⚡ PRACTICE</button>
      </div>
      <div id="tab-chat" style="flex:1;display:grid;grid-template-rows:auto 1fr auto;overflow:hidden;min-height:0">
        <div class="sys-bar"><span>TARGET</span><span id="sc-target"></span><span style="margin-left:10px;color:var(--text3)">SYSTEM: </span><span id="sc-sysprompt" style="font-size:10px"></span></div>
        <div id="chat-msgs" class="chat-msgs"></div>
        <div class="chat-input-row">
          <textarea id="chat-in" rows="2" placeholder="Enter your prompt… (Enter to send, Shift+Enter for newline)"
            onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();sendPrompt()}"></textarea>
          <button class="send-btn" id="send-btn" onclick="sendPrompt()">SEND</button>
        </div>
      </div>
      <div id="tab-library" style="display:none;flex:1;overflow-y:auto;min-height:0">
        <div id="lib-list" class="lib-panel"></div>
      </div>
      <div id="tab-supp" style="display:none;flex:1;overflow-y:auto;min-height:0">
        <div id="supp-list" class="supp-panel"></div>
      </div>
      <div id="tab-practice" style="display:none;flex:1;overflow-y:auto">
        <div id="practice-body" class="practice-panel"></div>
      </div>
    </div>
    <div class="side-col" style="width:320px;border-left:1px solid var(--border)">
      <div class="side-sec">
        <div class="side-head">OBJECTIVES</div>
        <div id="obj-list"></div>
      </div>
      <div class="side-sec">
        <div class="side-head" id="fi-head">FINDINGS (0)</div>
        <div id="fi-list"><div style="font-size:11px;color:var(--text3);padding:4px 0">None yet. Send prompts to trigger findings.</div></div>
        <button id="doc-btn" class="doc-btn" onclick="toggleDocumented()">✎ MARK AS DOCUMENTED</button>
      </div>
      <div class="hints-wrap">
        <details><summary>HINTS</summary><div id="hints-list"></div></details>
      </div>
    </div>
  </div>
</div>

<!-- REPORT VIEW -->
<div id="view-report" class="view">
  <div class="rep-hdr">
    <div class="rep-hdr-l">
      <div class="ey">TCM SECURITY — AI ASSESSMENT</div>
      <h2>REPORT BUILDER</h2>
      <div class="sub">Modelled on TCM Security Pasta Mentors report format</div>
    </div>
    <div class="rep-hdr-r">
      <button class="btn rep-mode-btn" data-mode="lab" onclick="setReportMode('lab')">LAB</button>
      <button class="btn rep-mode-btn" data-mode="client" onclick="setReportMode('client')">CLIENT</button>
      <button class="btn" onclick="exportSave()">↑ Export Save</button>
      <button class="btn" onclick="triggerImport('imp1')">↓ Import Save</button>
      <button class="btn btn-green" onclick="copyReport()">Copy Text</button>
      <button class="btn" style="border-color:#818cf8;color:#818cf8" onclick="downloadDocx()">↓ DOCX</button>
      <button class="btn" style="border-color:#60a5fa;color:#60a5fa" onclick="printReport()">↓ PDF/Print</button>
      <button class="btn" onclick="showView('map')">← MAP</button>
      <input id="imp1" type="file" accept=".json" style="display:none" onchange="importSave(event)">
    </div>
  </div>
  <div class="sev-strip" id="sev-strip"></div>
  <div class="tabs rep-tabs" id="rep-tabs">
    <button class="tab active" data-tab="edit" onclick="switchRepTab(this)">✏️ EDIT REPORT</button>
    <button class="tab" data-tab="preview" onclick="switchRepTab(this)">📄 PREVIEW</button>
    <button class="tab" id="ss-tab-btn" data-tab="screenshots" onclick="switchRepTab(this)">📷 SCREENSHOTS (0)</button>
    <button class="tab" data-tab="notes" onclick="switchRepTab(this)">📝 NOTES</button>
    <button class="tab" data-tab="reference" onclick="switchRepTab(this)">📚 REFERENCE</button>
    <button class="tab" data-tab="glossary" onclick="switchRepTab(this)">🔤 GLOSSARY</button>
  </div>
  <div class="rep-body">
    <div id="rep-edit" class="edit-panel"></div>
    <div id="rep-preview" class="preview-wrap" style="display:none"></div>
    <div id="rep-screenshots" class="ss-panel" style="display:none"></div>
    <div id="rep-notes" class="notes-panel" style="display:none">
      <div class="fl" style="margin-bottom:8px">ENGAGEMENT NOTES (private — not included in generated report)</div>
      <textarea id="notes-ta" rows="18" placeholder="Working notes, attack chain observations, failed attempts, timing notes…" oninput="S.notes=this.value;schedSave()"></textarea>
    </div>
    <div id="rep-reference" class="ref-panel" style="display:none"></div>
    <div id="rep-glossary" style="display:none;padding:20px;max-width:880px"></div>
  </div>
</div>

<!-- STUDY VIEW -->
<div id="view-study" class="view">
  <div class="content-hdr">
    <div>
      <div class="eyebrow">TCM SECURITY — CERTIFICATION PREP</div>
      <h2>STUDY — PRACTICAL AI PENTEST ASSOCIATE</h2>
    </div>
    <button class="btn" style="margin-left:auto" onclick="showView('map')">← MAP</button>
  </div>
  <div class="content-view">
    <div id="study-body" class="content-body"></div>
  </div>
</div>

<!-- MANUAL VIEW -->
<div id="view-manual" class="view">
  <div class="content-hdr">
    <div>
      <div class="eyebrow">TCM SECURITY — LAB DOCUMENTATION</div>
      <h2>MANUAL — HOW TO USE PAPALAB-TMC-LIVE</h2>
    </div>
    <button class="btn" style="margin-left:auto" onclick="showView('map')">← MAP</button>
  </div>
  <div class="content-view">
    <div id="manual-body" class="content-body"></div>
  </div>
</div>

<!-- LOGIN MODAL (hidden) -->
<div id="login-modal" class="modal-bg" style="display:none" onclick="if(event.target===this)closeLoginModal()">
  <div class="modal">
    <h3>Login to TMC Chatbot</h3>
    <div class="fb"><div class="fl">EMAIL</div><input id="login-email" type="email" value="customer@example.com" placeholder="email@example.com"></div>
    <div class="fb"><div class="fl">PASSWORD</div><input id="login-pwd" type="password" value="customer123" placeholder="password"></div>
    <div id="login-msg" style="font-size:11px;color:var(--red);min-height:16px;margin-top:4px"></div>
    <div class="modal-actions">
      <button class="btn" onclick="closeLoginModal()">Cancel</button>
      <button class="btn" style="border-color:var(--tmc);color:var(--tmc)" onclick="loginAsAdmin()">Admin Login</button>
      <button class="btn btn-green" onclick="doLogin()">Login</button>
    </div>
    <div style="margin-top:12px;font-size:10px;color:var(--text3)">
      Customer: customer@example.com / customer123<br>
      Admin: admin@toomanycables.com / admin123
    </div>
  </div>
</div>

<!-- RESET CONFIRM MODAL -->
<div id="reset-modal" class="modal-bg" style="display:none" onclick="if(event.target===this)closeResetModal()">
  <div class="modal">
    <h3 id="reset-modal-title" style="color:#ef4444">↺ Reset</h3>
    <p id="reset-modal-body" style="font-size:12px;color:var(--text2);margin:10px 0 16px;line-height:1.6"></p>
