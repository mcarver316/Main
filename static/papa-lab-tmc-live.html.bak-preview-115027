async function runRateLimit(){
  const selEl=document.getElementById('rl-endpoint');
  const sel=selEl?selEl.value:'custom';
  const customPath=document.getElementById('rl-custom-path')?.value.trim()||'/api/chat';
  const path=sel==='custom'?customPath:sel;
  const count=parseInt(document.getElementById('rl-count')?.value)||10;
  const delay=parseInt(document.getElementById('rl-delay')?.value)||0;
  const base=getTargetUrl();
  const url=base+path;
  const el=document.getElementById('rl-results');
  const btn=document.getElementById('rl-start-btn');
  if(btn)btn.disabled=true;
  el.innerHTML='<div style="font-size:10px;color:var(--text3)">Sending requests…</div>';
  let rows='';
  let rlAt=null;
  const isLogin=path.includes('login');
  const payload=isLogin?JSON.stringify({email:'probe@test.com',password:'test'}):JSON.stringify({message:'rate limit probe'});
  for(let i=1;i<=count;i++){
    let status=0;
    try{
      const r=await fetch(url,{method:'POST',headers:{'Content-Type':'application/json'},body:payload,signal:AbortSignal.timeout(5000)});
      status=r.status;
    }catch(e){status=0;}
    const cls=status===429?'resp-5xx':status===200||status===201?'resp-2xx':'resp-3xx resp-4xx';
    const note=status===429?'← RATE LIMIT':status===401?'invalid creds (expected)':status===0?'network err':'';
    rows+=`<div style="display:flex;gap:8px;font-size:10px;padding:2px 0">
      <span style="color:var(--text3);min-width:70px">Req ${i}/${count}</span>
      <span class="resp-status ${cls}" style="font-size:9px;padding:1px 5px">${status||'ERR'}</span>
      <span style="color:${status===429?'var(--red)':'var(--text3)'}">${note}</span>
    </div>`;
    el.innerHTML=rows;
    if(status===429&&rlAt===null){rlAt=i;rows+=`<div style="margin-top:8px;padding:8px;background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.3);border-radius:4px;font-size:10px;color:var(--red)">Rate limit triggered at request ${i}. Threshold: ${i-1} requests allowed.</div>`;el.innerHTML=rows;break;}
    if(delay>0)await new Promise(r=>setTimeout(r,delay));
  }
  if(rlAt===null)rows+=`<div style="margin-top:8px;font-size:10px;color:var(--orange)">No rate limit triggered in ${count} requests.</div>`;
  el.innerHTML=rows;
  if(rlAt!==null){el.innerHTML+=`<button class="btn" style="font-size:9px;margin-top:8px" onclick="_addReconFinding('No Rate Limiting on ${escAttr(path)}','Rate limit triggered at request ${rlAt}. Threshold: ${rlAt-1} requests before 429.')">+ Add Finding</button>`;}
  if(btn)btn.disabled=false;
}

