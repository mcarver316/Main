    if(item.type.startsWith('image/')){
      const f=item.getAsFile();if(!f)continue;
      const r=new FileReader();
      // In CLIENT mode, route to active CF card if one is focused
      if((S.reportMode||'lab')==='client'&&window._activeCfId){
