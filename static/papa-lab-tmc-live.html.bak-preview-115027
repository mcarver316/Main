  for(const k of Object.keys(S.findingData)){const fd=S.findingData[k];if(fd.screenshots)fd.screenshots=fd.screenshots.filter(s=>s.id!==id);}
  for(const cf of(S.clientFindings||[])){if(cf.screenshots)cf.screenshots=cf.screenshots.filter(s=>s.id!==id);}
  if(S.unassignedScreenshots)S.unassignedScreenshots=S.unassignedScreenshots.filter(s=>s.id!==id);
