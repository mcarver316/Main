  idor_ticket:{patterns:[/TMC-\d{6}.*(?:subject|description|status|priority|order)/si,/(?:subject|description|status|priority).*TMC-\d{6}/si,/ticket.*subject.*status/si,/order.*damaged.*ticket/si,/ticket details.*subject/si,/internal notes.*ticket/si]},
