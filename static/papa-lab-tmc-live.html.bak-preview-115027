async function sendPrompt(){
  const input=document.getElementById('chat-in').value.trim();
  if(!input||!currentScenario)return;
  const btn=document.getElementById('send-btn');btn.disabled=true;
  document.getElementById('chat-in').value='';
  if(!S.messages[currentScenario])S.messages[currentScenario]=[];
  S.messages[currentScenario].push({role:'user',content:input});
  // Attempt counter
  if(!S.attemptCounts)S.attemptCounts={};
  S.attemptCounts[currentScenario]=(S.attemptCounts[currentScenario]||0)+1;
  renderChat(currentScenario);
  const _lf=window._pendingLibraryFindings||null;window._pendingLibraryFindings=null;
  let responseText='',meta=null,triggered=[],_wasLiveCooperation=false;
  try{
    if(_liveMode){
      const d=await sendPromptLive(currentScenario,input);
      responseText=d.response||d.message||'(no response)';
      meta={rag_used:d.rag_used,rag_context_length:d.rag_context_length,response_time_ms:d.response_time_ms};
      if(_lf&&_lf.length){
        if(isLiveRefusal(responseText)){responseText=getSimResponse(currentScenario,_lf);triggered=_lf;}
        else{triggered=_lf;_wasLiveCooperation=true;}
      }else{
        if(isLiveRefusal(responseText)){const r=simulate(currentScenario,input);responseText=r.text;triggered=r.triggered;}
        else triggered=detectFindings(currentScenario,responseText);
      }
    } else {
      if(_lf&&_lf.length){responseText=getSimResponse(currentScenario,_lf);triggered=_lf;}
      else{const r=simulate(currentScenario,input);responseText=r.text;triggered=r.triggered;}
    }
  }catch(e){responseText='Connection error: '+e.message+'\n\nIs the TMC chatbot running at localhost:5001?';}
  // Record triggered findings
  if(!S.triggered[currentScenario])S.triggered[currentScenario]=[];
  for(const k of triggered){
    const isNew=!S.triggered[currentScenario].includes(k);
    if(isNew){S.triggered[currentScenario].push(k);getFD(k);}
    const m=FM[k];if(m&&(isNew||_wasLiveCooperation)){
      S.messages[currentScenario].push({role:'toast',id:m.id,title:m.title,severity:m.severity});
    }
  }
