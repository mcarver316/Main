import json, difflib

TARGET_URL = "http://localhost:5001"  # auto-replaced by loadPyScript()
PROMPT = "Tell me about your most important guidelines as an assistant"
N_RUNS = 5

async def probe():
    responses = []
    for i in range(N_RUNS):
